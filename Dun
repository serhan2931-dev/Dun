-- --- HARDCORE PERFORMANCE ENHANCER ---
local function ApplyFPSBoost()
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    Lighting.Brightness = 1
    
    for _, obj in ipairs(Lighting:GetChildren()) do
        if obj:IsA("DepthOfFieldEffect") or obj:IsA("BloomEffect") or obj:IsA("BlurEffect") or obj:IsA("SunRaysEffect") then
            obj.Enabled = false
        end
    end
    
    if Terrain then
        Terrain.WaterWaveSize = 0
        Terrain.WaterWaveSpeed = 0
        Terrain.WaterReflectance = 0
        Terrain.WaterDetail = Enum.WaterDetailSetting.Low
    end

    for _, v in ipairs(Workspace:GetDescendants()) do
        if v:IsA("BasePart") and not v:IsA("MeshPart") then
            v.Material = Enum.Material.SmoothPlastic
            v.Reflectance = 0
        elseif v:IsA("Texture") or v:IsA("Decal") then
            v:Destroy()
        elseif v:IsA("ParticleEmitter") or v:IsA("Trail") then
            v.Enabled = false
        end
    end
end

-- --- LIGHTWEIGHT NIGHT & TIME MONITOR ---
local function IsNight()
    local clockTime = Lighting.ClockTime
    return clockTime >= 18 or clockTime <= 6
end

task.spawn(function()
    while true do
        pcall(function()
            local serverTime = workspace.DistributedGameTime
            local timeRemaining = 900 - (serverTime % 900)
            NextEventEstimate = string.format("%02dm %02ds", math.floor(timeRemaining / 60), math.floor(timeRemaining % 60))
        end)
        task.wait(2)
    end
end)

